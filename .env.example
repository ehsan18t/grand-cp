# OpenNext/Cloudflare local dev runtime variables
# Copy to .env (or .env.local) and fill values.

NEXTJS_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare D1 (for drizzle-kit migrations)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_DATABASE_ID=your_database_id
CLOUDFLARE_D1_TOKEN=your_api_token

# Better Auth
BETTER_AUTH_SECRET=your-32-char-secret-key-here

# Google OAuth (required for social sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# For Cloudflare API access (required for deployment)
# What token permissions you need (minimum for this setup):
# 
# Account → Workers Scripts: Edit
# Account → Workers KV Storage: Edit
# Account → D1: Edit
# Account → Account Settings: Read
CLOUDFLARE_API_TOKEN=your_cf_api_token_here
CF_API_TOKEN=your_cf_api_token_here
